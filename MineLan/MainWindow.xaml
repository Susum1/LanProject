<Window x:Class="MineLAN.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MineLAN"
        Width="900"
        Height="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#1E1E1E">

    <Grid>

        <Border
            Margin="25"
            Background="#2B2B2B"
            CornerRadius="12">

            <StackPanel Margin="25">

                <TextBlock
                    x:Name="ApplicationTitle"
                    FontSize="34"
                    FontWeight="Bold"
                    Foreground="White"/>

                <TextBlock
                    x:Name="VersionText"
                    Margin="0,5,0,20"
                    FontSize="16"
                    Foreground="#AAAAAA"/>

                <Separator Margin="0,0,0,20"/>

                <TextBlock
                    Text="Статус"
                    FontSize="18"
                    Foreground="#AAAAAA"/>

                <TextBlock
                    x:Name="StatusText"
                    Margin="0,5,0,25"
                    FontSize="28"
                    Foreground="#7CFC00"/>

                <Border
                    Margin="0,15,0,20"
                    Padding="15"
                    CornerRadius="8"
                    Background="#363636">

                    <StackPanel>

                        <TextBlock
                            x:Name="InternetText"
                            FontSize="16"
                            Foreground="White"/>

                        <TextBlock
                            x:Name="AdminText"
                            Margin="0,8,0,0"
                            FontSize="16"
                            Foreground="White"/>

                        <TextBlock
                            x:Name="WireGuardText"
                            Margin="0,8,0,0"
                            FontSize="16"
                            Foreground="White"/>

                        <TextBlock
                            x:Name="SystemInfoText"
                            Margin="0,15,0,0"
                            FontSize="14"
                            Foreground="#BBBBBB"
                            TextWrapping="Wrap"/>

                        <TextBlock
                            x:Name="WireGuardVersionText"
                            Margin="0,10,0,0"
                            FontSize="13"
                            Foreground="#BBBBBB"
                            TextWrapping="Wrap"/>

                        <TextBlock
                            x:Name="WireGuardPathText"
                            Margin="0,5,0,0"
                            FontSize="12"
                            Foreground="#999999"
                            TextWrapping="Wrap"/>
                        
                    </StackPanel>
                </Border>

                <GroupBox
                     Header="Профили"
                     Margin="0,20,0,10">

                     <ListBox
                         x:Name="ProfilesList"
                         Height="120"/>

                </GroupBox>

                <Button
                    x:Name="ConnectButton"
                    Width="220"
                    Height="45"
                    HorizontalAlignment="Left"
                    Content="Подключиться"/>

                <TextBlock
                    x:Name="PathText"
                    Margin="0,20,0,0"
                    FontSize="13"
                    Foreground="#AAAAAA"
                    TextWrapping="Wrap"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>